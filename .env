# Variáveis de ambiente para desenvolvimento local.
# Valores de produção NUNCA devem entrar aqui — injete via secret manager / CI.

# --- JWT ---
JWT_SECRET=dev-secret-local-nunca-use-em-producao
JWT_TTL=15m

# --- Banco de dados ---
# memory: sem dependências externas (padrão)
# mongo:  requer MONGO_URI
DB_DRIVER=memory
# DB_DRIVER=mongo
# MONGO_URI=mongodb+srv://<usuario>:<senha>@<host>/<db>
# MONGO_DB=eco
