package config

import "os"

// Config agrupa as opções de runtime da API.
type Config struct {
	Addr string

	// DBDriver seleciona o backend de persistência: "memory" (padrão) ou "mongo".
	DBDriver string
	// MongoURI e MongoDB só são usados quando DBDriver == "mongo".
	MongoURI string
	MongoDB  string
}

// Load lê variáveis de ambiente e devolve a configuração efetiva.
func Load() Config {
	addr := os.Getenv("ADDR")
	if addr == "" {
		addr = ":8080"
	}
	driver := os.Getenv("DB_DRIVER")
	if driver == "" {
		driver = "memory"
	}
	mongoDB := os.Getenv("MONGO_DB")
	if mongoDB == "" {
		mongoDB = "{{.Name}}"
	}
	return Config{
		Addr:     addr,
		DBDriver: driver,
		MongoURI: os.Getenv("MONGO_URI"),
		MongoDB:  mongoDB,
	}
}
