package config

import (
	"os"
	"time"
)

// Config agrupa as opções de runtime da API.
type Config struct {
	Addr string

	// DBDriver seleciona o backend de persistência: "memory" (padrão) ou "mongo".
	DBDriver string
	// MongoURI e MongoDB só são usados quando DBDriver == "mongo".
	MongoURI string
	MongoDB  string

	// JWTSecret assina os tokens de autenticação. Obrigatório; nunca hard-code.
	JWTSecret string
	// JWTTTL é a validade de cada token emitido (default 15m).
	JWTTTL time.Duration
}

// Load lê variáveis de ambiente e devolve a configuração efetiva.
func Load() Config {
	addr := os.Getenv("ADDR")
	if addr == "" {
		addr = ":8080"
	}
	driver := os.Getenv("DB_DRIVER")
	if driver == "" {
		driver = "memory"
	}
	mongoDB := os.Getenv("MONGO_DB")
	if mongoDB == "" {
		mongoDB = "{{.Name}}"
	}
	ttl := 15 * time.Minute
	if v := os.Getenv("JWT_TTL"); v != "" {
		if d, err := time.ParseDuration(v); err == nil {
			ttl = d
		}
	}
	return Config{
		Addr:      addr,
		DBDriver:  driver,
		MongoURI:  os.Getenv("MONGO_URI"),
		MongoDB:   mongoDB,
		JWTSecret: os.Getenv("JWT_SECRET"),
		JWTTTL:    ttl,
	}
}
