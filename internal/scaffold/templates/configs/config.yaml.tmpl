# Configuração padrão da API {{.Name}}.
# Substitua por env vars em produção (ex.: ADDR=:8080).
addr: ":8080"

# Backend de persistência: "memory" (padrão, zero deps) ou "mongo".
# Em produção, prefira env vars: DB_DRIVER, MONGO_URI, MONGO_DB.
db_driver: "memory"
mongo_uri: "mongodb://localhost:27017"
mongo_db: "{{.Name}}"
