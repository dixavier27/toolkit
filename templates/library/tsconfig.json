{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "types": ["bun-types", "node"]
  },
  "include": ["src"]
}
