    "check": "eco check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@dixavier27/eco": "github:dixavier27/eco#v2.4.0",
    "@types/node": "^25.8.0",
    "bun-types": "^1.3.14",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
