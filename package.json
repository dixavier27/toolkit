{
  "name": "toolkit",
  "version": "1.0.0",
  "description": "CLI toolkit para build, package, obfuscate e release de apps Biglaw",
  "type": "module",
  "bin": {
    "biglaw-scripts": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target=bun --minify",
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "clean": "rm -rf dist release",
    "changeset": "changeset",
    "version": "changeset version",
    "release:publish": "bun run build && changeset publish",
    "prepublishOnly": "bun run typecheck && bun run lint && bun run build"
  },
  "dependencies": {
    "javascript-obfuscator": "^4.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.12",
    "@types/node": "^25.8.0",
    "bun-types": "^1.3.14",
    "typescript": "^5.8.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
