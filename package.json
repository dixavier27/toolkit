{
  "name": "@dixavier27/eco",
  "version": "2.0.0",
  "description": "eco — toolkit de build, package, obfuscate e release para apps Bun",
  "type": "module",
  "bin": {
    "eco": "./dist/index.js"
  },
  "files": ["dist", "src", "templates", "README.md", "LICENSE"],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target=bun --minify",
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "clean": "rm -rf dist release",
    "changeset": "changeset",
    "version": "changeset version",
    "release:publish": "bun run build && changeset publish",
    "prepublishOnly": "bun run typecheck && bun run lint && bun run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "javascript-obfuscator": "^5.4.2",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.8.0",
    "bun-types": "^1.3.14",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
